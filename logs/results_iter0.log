    a_fit = median_a[valid_mask]
    
    ax.plot(r_fit, a_fit, 'ko', label='Median |a| vs r')
    
    def power_law(r, A, n): return A * r**(-n)
    def screened(r, A, lam): return A * np.exp(-r / lam) / r
    def yukawa(r, A, lam): return A * np.exp(-r / lam) / r**2
    
    best_model = 'unknown'
    force_n = 0.0
    
    if len(r_fit) > 2:
        log_r = np.log(r_fit)
        log_a = np.log(a_fit)
        slope, intercept, _, _, _ = stats.linregress(log_r, log_a)
        n_guess = -slope
        A_guess = np.exp(intercept)
        
        try:
            popt_pl, _ = curve_fit(power_law, r_fit, a_fit, p0=[A_guess, n_guess], bounds=(0, np.inf))
        except:
            popt_pl = [A_guess, n_guess]
            
        try:
            popt_sc, _ = curve_fit(screened, r_fit, a_fit, p0=[A_guess, 0.1], bounds=(0, np.inf), maxfev=10000)
        except:
            popt_sc = [A_guess, 0.1]
            
        try:
            popt_yu, _ = curve_fit(yukawa, r_fit, a_fit, p0=[A_guess, 0.1], bounds=(0, np.inf), maxfev=10000)
        except:
            popt_yu = [A_guess, 0.1]
            
        r_plot = np.linspace(np.min(r_fit), np.max(r_fit), 100)
        ax.plot(r_plot, power_law(r_plot, *popt_pl), 'r-', label='Power Law (n=' + str(round(popt_pl[1], 2)) + ')')
        ax.plot(r_plot, screened(r_plot, *popt_sc), 'g--', label='Screened')
        ax.plot(r_plot, yukawa(r_plot, *popt_yu), 'b-.', label='Yukawa')
        
        def compute_aic(y_true, y_pred, k):
            ssr = np.sum((y_true - y_pred)**2)
            if ssr == 0: return -np.inf
            n_pts = len(y_true)
            return 2*k + n_pts * np.log(ssr / n_pts)
            
        aic_pl = compute_aic(a_fit, power_law(r_fit, *popt_pl), 2)
        aic_sc = compute_aic(a_fit, screened(r_fit, *popt_sc), 2)
        aic_yu = compute_aic(a_fit, yukawa(r_fit, *popt_yu), 2)
        
        best_aic = min(aic_pl, aic_sc, aic_yu)
        if best_aic == aic_pl: best_model = 'power_law'
        elif best_aic == aic_sc: best_model = 'screened'
        else: best_model = 'yukawa'
        force_n = popt_pl[1]
        
